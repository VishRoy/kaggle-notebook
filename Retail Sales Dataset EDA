    "import pandas as pd\n",
    "from scipy import stats\n",
    "\n",
    "# Step 1: build the contingency table (counts of each Category x Gender combo)\n",
    "ct = pd.crosstab(df[\"Product Category\"], df[\"Gender\"])\n",
    "print(ct)\n",
    "\n",
    "# Step 2: run the test\n",
    "chi2, p_value, dof, expected = stats.chi2_contingency(ct)\n",
    "\n",
    "print(f\"chi2 = {chi2:.3f}\")\n",
    "print(f\"p-value = {p_value:.4f}\")\n",
    "print(f\"degrees of freedom = {dof}\")\n",
    "\n",
    "if p_value < 0.05:\n",
    "    print(\"Reject H0 — Product_Category and Gender are significantly associated\")\n",
    "else:\n",
    "    print(\"Fail to reject H0 — no significant association detected\")"
   ]
